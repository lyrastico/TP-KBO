# --- Stockage physique des données MongoDB --------------------------------
# Dossier hôte où MongoDB écrit ses données (bind mount du conteneur).
# Défaut portable : sous-dossier du projet. Si le disque système manque de place
# (le KBO complet pèse plusieurs Go), pointer vers un autre disque, ex :
#   Windows : MONGO_DATA_HOST=D:/DockerData/kbo-mongo
#   Linux   : MONGO_DATA_HOST=/mnt/data/kbo-mongo
MONGO_DATA_HOST=./data/mongo

# --- MongoDB ---------------------------------------------------------------
MONGO_URI=mongodb://root:example@localhost:27017/
MONGO_DB=kbo
BRONZE_COLLECTION=enterprise_finale
SILVER_COLLECTION=enterprise_silver
STATE_COLLECTION=state_nbb

# --- Données KBO -----------------------------------------------------------
# Dossier contenant les CSV KBO Open Data (voir README pour le téléchargement).
KBO_DIR=data/KBO

# --- Scraping NBB CBSO -----------------------------------------------------
# API publique de consultation (aucune clé requise). Année d'exercice minimale.
NBB_MIN_YEAR=2021

# --- Stockage HDFS des dépôts financiers -----------------------------------
# Backend : "local" (miroir sur disque) ou "webhdfs"
HDFS_BACKEND=local
HDFS_LOCAL_DIR=data/hdfs
# Utilisé si HDFS_BACKEND=webhdfs
WEBHDFS_URL=http://localhost:9870
WEBHDFS_USER=root
